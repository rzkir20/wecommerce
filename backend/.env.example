PORT=8787

JWT_SECRET=

#
# Prisma (recommended)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Example:
# DATABASE_URL="mysql://root:@127.0.0.1:3306/wecommerce"
#
DATABASE_URL="mysql://root:@127.0.0.1:3306/wecommerce"

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=wecommerce

# Optional: extra origins (comma-separated) for CORS
# CORS_ORIGIN=https://your-app.com

# Optional: shared auth cookie across subdomains
# Example valid values:
# SESSION_COOKIE_DOMAIN=.rizkiramadhan.web.id
# SESSION_COOKIE_DOMAIN=rizkiramadhan.web.id
# SESSION_COOKIE_DOMAIN=http://rizkiramadhan.web.id/  (will be normalized automatically)
SESSION_COOKIE_DOMAIN=

# Optional: force Secure attribute on session cookie
# true  -> always Secure
# false -> never Secure (local HTTP development)
# empty -> auto (Secure on HTTPS / x-forwarded-proto=https)
SESSION_COOKIE_SECURE=

# Optional: control SameSite cookie policy
# lax    -> default, cocok untuk same-site/subdomain
# strict -> paling ketat
# none   -> wajib untuk frontend & API beda domain (cross-site), butuh HTTPS
SESSION_COOKIE_SAMESITE=lax
