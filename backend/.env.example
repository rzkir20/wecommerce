PORT=8787
JWT_SECRET=replace-with-strong-secret
CORS_ORIGIN=http://localhost:3000
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# `prisma migrate` / Studio di development saja. Login/register & middleware auth memakai Supabase JS (REST), bukan Prisma runtime.
# Direct (5432) for migrate locally; pooler (6543 + ?pgbouncer=true) if you still run Prisma queries from serverless.
DATABASE_URL=postgresql://postgres:password@db.your-project-id.supabase.co:5432/postgres
# Optional: parent domain (leading dot) when frontend and API are on different subdomains, e.g. .example.com
SESSION_COOKIE_DOMAIN=
# Set true temporarily to include `detail` on 503 responses (debug only).
EXPOSE_ERROR_DETAILS=
