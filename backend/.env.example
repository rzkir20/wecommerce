PORT=8787

JWT_SECRET=

#
# Prisma (recommended)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Example:
# DATABASE_URL="mysql://root:@127.0.0.1:3306/wecommerce"
#
DATABASE_URL="mysql://root:@127.0.0.1:3306/wecommerce"

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=wecommerce

# Optional: extra origins (comma-separated) for CORS
# CORS_ORIGIN=https://your-app.com
