generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admins
  affiliate
  users
  seller
}

enum SellerApplicationStatus {
  pending
  approved
  rejected
}

enum ShopStatus {
  active
  suspended
}

model User {
  id                  String               @id @default(uuid()) @db.Uuid
  email               String               @unique @db.VarChar(255)
  name                String               @db.VarChar(255)
  avatar              String?              @db.VarChar(512)
  phone               String?              @db.VarChar(32)
  role                UserRole             @default(users)
  is_verified         Boolean              @default(false)
  password_hash       String               @db.VarChar(255)
  created_at          DateTime             @default(now()) @db.Timestamptz(6)
  login_histories     LoginHistory[]
  logs                Log[]
  qr_login_sessions   QrLoginSession[]
  seller_applications SellerApplication[]
  shops               Shop[]

  @@map("users")
}

model SellerApplication {
  id               String                  @id @default(uuid()) @db.Uuid
  user_id          String                  @db.Uuid
  store_name       String                  @db.VarChar(255)
  ktp_number       String                  @db.VarChar(32)
  ktp_image        String                  @db.VarChar(512)
  selfie_ktp       String                  @db.VarChar(512)
  status           SellerApplicationStatus @default(pending)
  rejection_reason String?                 @db.VarChar(1000)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([user_id], map: "idx_seller_applications_user_id")
  @@map("seller_applications")
}

model Shop {
  id          String     @id @default(uuid()) @db.Uuid
  user_id     String     @unique @db.Uuid
  name        String     @db.VarChar(255)
  slug        String     @unique @db.VarChar(255)
  description String?    @db.Text
  status      ShopStatus @default(active)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("shops")
}

model Log {
  id           String   @id @default(uuid()) @db.Uuid
  action       String   @db.VarChar(100)
  description  String?  @db.VarChar(1000)
  target_table String?  @db.VarChar(100)
  target_id    String?  @db.VarChar(191)
  user_id      String?  @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  user         User?    @relation(fields: [user_id], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([user_id], map: "idx_logs_user_id")
  @@index([target_table, target_id], map: "idx_logs_target")
  @@map("logs")
}

model QrLoginSession {
  token               String    @id @db.VarChar(128)
  status              String    @db.VarChar(16)
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  expires_at          DateTime  @db.Timestamptz(6)
  approved_user_id    String?   @db.Uuid
  approved_user       User?     @relation(fields: [approved_user_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  approved_user_name  String?   @db.VarChar(255)
  approved_user_email String?   @db.VarChar(255)
  approved_user_phone String?   @db.VarChar(32)
  auth_token          String?   @db.Text
  used_at             DateTime? @db.Timestamptz(6)

  @@index([approved_user_id], map: "idx_qr_login_sessions_approved_user_id")
  @@index([status, expires_at], map: "idx_qr_login_sessions_status_expires_at")
  @@map("qr_login_sessions")
}

model LoginHistory {
  id                Int       @id @default(autoincrement())
  user_id           String    @db.Uuid
  token_id          String    @unique @db.VarChar(128)
  ip_address        String?   @db.VarChar(64)
  user_agent        String?   @db.VarChar(1000)
  location          String?   @db.VarChar(255)
  device            String?   @db.VarChar(255)
  login_date        DateTime  @default(now()) @db.Timestamptz(6)
  logout_date       DateTime? @db.Timestamptz(6)
  is_active         Boolean   @default(true)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime  @updatedAt @db.Timestamptz(6)
  user              User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([user_id], map: "idx_login_histories_user_id")
  @@index([user_id, login_date], map: "idx_login_histories_user_login_date")
  @@map("login_histories")
}
