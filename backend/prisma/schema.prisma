generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @db.Char(36)
  email        String   @unique @db.VarChar(255)
  name         String   @db.VarChar(255)
  avatar       String?  @db.VarChar(512)
  phone        String?  @db.VarChar(32)
  role         Role     @default(users)
  isVerified   Boolean  @default(false) @map("is_verified")
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  logs         Log[]

  @@map("users")
}

enum Role {
  super_admins
  affiliate
  users
  seller
}

model Log {
  id          String   @id @db.Char(36)
  action      String   @db.VarChar(100)
  description String?  @db.VarChar(1000)
  targetTable String?  @map("target_table") @db.VarChar(100)
  targetId    String?  @map("target_id") @db.VarChar(191)
  userId      String?  @map("user_id") @db.Char(36)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([userId], map: "idx_logs_user_id")
  @@index([targetTable, targetId], map: "idx_logs_target")
  @@map("logs")
}

